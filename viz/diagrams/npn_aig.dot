// Main SVG for npn: a host AIG with a 4-leaf cut implemented INEFFICIENTLY
// as 5 fanin-2 ANDs (t1..t5) computing f = TT 0x020F over {a, b, c, d}.
// Rewrite will replace this 5-node MFFC with the 3-node canonical-derived
// subgraph (n1, n2, F).
//
// Inefficient (initial) implementation:
//   t1 = ¬c · ¬d
//   t2 = a · ¬b
//   t3 = t2 · ¬c          (¬c shows up twice — redundant; rewrite catches this)
//   t4 = t3 · d
//   t5 = ¬t1 · ¬t4         (= ¬(t1 + t4))
//   f  = ¬t5               (the edge t5 → G is dashed)
//
// Slot-in replacement (after pPhases=0x01 + pPerms=swap-x2,x3 applied to
// canonical of class 12):
//   n1 = a · ¬b
//   n2 = d · ¬n1
//   F  = ¬c · ¬n2          ( ≡ TT 0x020F )
//
// Both states are baked into the same SVG; the walkthrough toggles which
// is shown via the "hidden" highlight class.
digraph npn_aig {
    rankdir = TB
    ranksep = 0.45
    nodesep = 0.3
    bgcolor = "transparent"
    label = "Host AIG: a 4-leaf cut at f, currently 5 ANDs (TT = 0x020F)"
    labelloc = "t"
    fontname = "monospace"
    fontsize = 13

    node [fontname = "monospace", fontsize = 13, color = "#333333"]
    edge [color = "#333333", penwidth = 1.4]

    { rank = source
      a [id="node-a", label="a", shape=plaintext, fontsize=18, fontcolor="#1a4d80"]
      b [id="node-b", label="b", shape=plaintext, fontsize=18, fontcolor="#1a4d80"]
      c [id="node-c", label="c", shape=plaintext, fontsize=18, fontcolor="#1a4d80"]
      d [id="node-d", label="d", shape=plaintext, fontsize=18, fontcolor="#1a4d80"]
      e [id="node-e", label="e", shape=plaintext, fontsize=18, fontcolor="#1a4d80"]
    }

    // ---- Inefficient 5-AND cut (t1..t5) ----
    t1 [id="node-t1", label="t1", shape=circle, width=0.5, fixedsize=true, style=filled, fillcolor="#f7f7f7"]
    t2 [id="node-t2", label="t2", shape=circle, width=0.5, fixedsize=true, style=filled, fillcolor="#f7f7f7"]
    t3 [id="node-t3", label="t3", shape=circle, width=0.5, fixedsize=true, style=filled, fillcolor="#f7f7f7"]
    t4 [id="node-t4", label="t4", shape=circle, width=0.5, fixedsize=true, style=filled, fillcolor="#f7f7f7"]
    t5 [id="node-t5", label="t5", shape=circle, width=0.5, fixedsize=true, style=filled, fillcolor="#f7f7f7"]

    // ---- Replacement 3-AND subgraph (n1, n2, F) ----
    n1 [id="node-n1", label="n1", shape=circle, width=0.5, fixedsize=true, style=filled, fillcolor="#f7f7f7"]
    n2 [id="node-n2", label="n2", shape=circle, width=0.5, fixedsize=true, style=filled, fillcolor="#f7f7f7"]
    F  [id="node-F",  label="F",  shape=circle, width=0.5, fixedsize=true, style=filled, fillcolor="#f7f7f7"]

    // ---- Downstream context ----
    G  [id="node-G",  label="G",  shape=circle, width=0.5, fixedsize=true, style=filled, fillcolor="#f7f7f7"]

    { rank = sink
      PO [id="node-PO", label="PO", shape=plaintext, fontsize=14, fontcolor="#806000"]
    }

    // Inefficient cut edges
    a -> t2 [id="edge-a-t2"]
    b -> t2 [id="edge-b-t2", style=dashed]
    c -> t1 [id="edge-c-t1", style=dashed]
    d -> t1 [id="edge-d-t1", style=dashed]
    c -> t3 [id="edge-c-t3", style=dashed]
    t2 -> t3 [id="edge-t2-t3"]
    d -> t4 [id="edge-d-t4"]
    t3 -> t4 [id="edge-t3-t4"]
    t1 -> t5 [id="edge-t1-t5", style=dashed]
    t4 -> t5 [id="edge-t4-t5", style=dashed]
    t5 -> G  [id="edge-t5-G",  style=dashed]

    // Replacement edges
    a -> n1 [id="edge-a-n1"]
    b -> n1 [id="edge-b-n1", style=dashed]
    d -> n2 [id="edge-d-n2"]
    n1 -> n2 [id="edge-n1-n2", style=dashed]
    c -> F  [id="edge-c-F",  style=dashed]
    n2 -> F [id="edge-n2-F", style=dashed]
    F -> G  [id="edge-F-G"]

    // Always-visible context
    e -> G  [id="edge-e-G"]
    G -> PO [id="edge-G-PO"]
}
