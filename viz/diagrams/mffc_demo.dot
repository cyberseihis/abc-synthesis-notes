// Circuit designed so MFFC(f) is a strict subset of internal ANDs.
// n1 has fanout 2 (f and g), so it survives the deref of f → not in MFFC.
// Other internal ANDs (n2, n3, n4) are private to f → in MFFC.
digraph mffc_demo {
    rankdir = TB
    ranksep = 0.55
    nodesep = 0.45
    bgcolor = "transparent"
    node [fontname = "monospace", fontsize = 14, color = "#333333"]
    edge [color = "#333333", penwidth = 1.4]

    { rank = source
      a [id="node-a", label="a", shape=plaintext, fontsize=18, fontcolor="#1a4d80"]
      b [id="node-b", label="b", shape=plaintext, fontsize=18, fontcolor="#1a4d80"]
      c [id="node-c", label="c", shape=plaintext, fontsize=18, fontcolor="#1a4d80"]
      d [id="node-d", label="d", shape=plaintext, fontsize=18, fontcolor="#1a4d80"]
    }

    n1 [id="node-n1", label="n1", shape=circle, width=0.55, fixedsize=true, style=filled, fillcolor="#f7f7f7"]
    n2 [id="node-n2", label="n2", shape=circle, width=0.55, fixedsize=true, style=filled, fillcolor="#f7f7f7"]
    n3 [id="node-n3", label="n3", shape=circle, width=0.55, fixedsize=true, style=filled, fillcolor="#f7f7f7"]
    n4 [id="node-n4", label="n4", shape=circle, width=0.55, fixedsize=true, style=filled, fillcolor="#f7f7f7"]
    f  [id="node-f",  label="f",  shape=circle, width=0.55, fixedsize=true, style=filled, fillcolor="#f7f7f7"]
    g  [id="node-g",  label="g",  shape=circle, width=0.55, fixedsize=true, style=filled, fillcolor="#f7f7f7"]

    { rank = sink
      POf [id="node-POf", label="PO_f", shape=plaintext, fontsize=13, fontcolor="#806000"]
      POg [id="node-POg", label="PO_g", shape=plaintext, fontsize=13, fontcolor="#806000"]
    }

    a -> n1 [id="edge-a-n1"]
    b -> n1 [id="edge-b-n1"]
    a -> n2 [id="edge-a-n2"]
    c -> n2 [id="edge-c-n2"]
    b -> n3 [id="edge-b-n3"]
    c -> n3 [id="edge-c-n3"]
    n2 -> n4 [id="edge-n2-n4"]
    n3 -> n4 [id="edge-n3-n4"]
    n1 -> f  [id="edge-n1-f"]
    n4 -> f  [id="edge-n4-f"]
    n1 -> g  [id="edge-n1-g"]
    d  -> g  [id="edge-d-g"]
    f  -> POf [id="edge-f-POf"]
    g  -> POg [id="edge-g-POg"]
}
