// Circuit for the MFFC walkthrough.
// Target node t. Cut for t is {p, q, e, h} — two internal ANDs (p, q)
// and two PIs (e, h). The boost on cut leaves is what stops the deref
// from walking past p and q into a, b, c, d.
//
// Every node carries an xlabel "[N]" where N is its initial fanout count.
// Per-step textReplace updates each node's "name\n[count]" to animate
// the counters as deref/ref decrements them.
digraph mffc_demo {
    rankdir = TB
    ranksep = 0.7
    nodesep = 0.55
    bgcolor = "transparent"
    node [fontname = "monospace", fontsize = 14, color = "#333333"]
    edge [color = "#333333", penwidth = 1.4]

    { rank = source
      a [id="node-a", label="a", xlabel="[1]", shape=plaintext, fontsize=18, fontcolor="#1a4d80"]
      b [id="node-b", label="b", xlabel="[1]", shape=plaintext, fontsize=18, fontcolor="#1a4d80"]
      c [id="node-c", label="c", xlabel="[1]", shape=plaintext, fontsize=18, fontcolor="#1a4d80"]
      d [id="node-d", label="d", xlabel="[1]", shape=plaintext, fontsize=18, fontcolor="#1a4d80"]
      e [id="node-e", label="e", xlabel="[1]", shape=plaintext, fontsize=18, fontcolor="#1a4d80"]
      h [id="node-h", label="h", xlabel="[1]", shape=plaintext, fontsize=18, fontcolor="#1a4d80"]
    }

    p [id="node-p", label="p", xlabel="[1]", shape=circle, width=0.55, fixedsize=true, style=filled, fillcolor="#f7f7f7"]
    q [id="node-q", label="q", xlabel="[1]", shape=circle, width=0.55, fixedsize=true, style=filled, fillcolor="#f7f7f7"]
    m [id="node-m", label="m", xlabel="[1]", shape=circle, width=0.55, fixedsize=true, style=filled, fillcolor="#f7f7f7"]
    n [id="node-n", label="n", xlabel="[1]", shape=circle, width=0.55, fixedsize=true, style=filled, fillcolor="#f7f7f7"]
    t [id="node-t", label="t", xlabel="[1]", shape=circle, width=0.55, fixedsize=true, style=filled, fillcolor="#f7f7f7"]

    { rank = sink
      PO [id="node-PO", label="PO", shape=plaintext, fontsize=13, fontcolor="#806000"]
    }

    a -> p [id="edge-a-p"]
    b -> p [id="edge-b-p"]
    c -> q [id="edge-c-q"]
    d -> q [id="edge-d-q"]
    p -> m [id="edge-p-m"]
    q -> m [id="edge-q-m"]
    e -> n [id="edge-e-n"]
    h -> n [id="edge-h-n"]
    m -> t [id="edge-m-t"]
    n -> t [id="edge-n-t"]
    t -> PO [id="edge-t-PO"]
}
