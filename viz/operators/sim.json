        "node-n123": "n123\n—",
        "node-f":    "f\n—"
      },
      "panes": [
        {
          "type": "bitvec",
          "title": "sim(t1) = 0xAAAAAAAA &amp; 0xCCCCCCCC = 0x88888888",
