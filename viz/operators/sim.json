        "node-f":    ["considering"],
        "edge-n12-n123": ["active"],
        "edge-t3-n123":  ["active"],
        "edge-n123-f":   ["active"]
      },
      "textReplace": {
        "node-x0":   "x0\nAAAAAAAA",
        "node-x1":   "x1\nCCCCCCCC",
